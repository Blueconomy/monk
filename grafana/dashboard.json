{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "barchart", "name": "Bar chart", "version": ""},
    {"type": "panel", "id": "piechart", "name": "Pie chart", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "monk — AI Agent Cost Leak Detector. Visualises findings, waste estimates, and session analysis.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "GitHub",
      "url": "https://github.com/Blueconomy/monk",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 10},
            {"color": "red", "value": 50}
          ]},
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "title": "Total Findings",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(monk_findings_total)", "legendFormat": "Findings", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "title": "🔴 High Severity",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "monk_high_severity_findings_total", "legendFormat": "High", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"fixedColor": "orange", "mode": "fixed"}, "decimals": 2, "unit": "currencyUSD"},
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "title": "Est. Waste / Day",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(monk_waste_usd_per_day)", "legendFormat": "$/day", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "title": "Sessions Analyzed",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "monk_sessions_analyzed_total", "legendFormat": "Sessions", "refId": "A"}]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "id": 101,
      "title": "Findings Breakdown",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 14, "x": 0, "y": 7},
      "id": 5,
      "options": {"barRadius": 0.05, "barWidth": 0.7, "fillOpacity": 80, "groupWidth": 0.7, "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "orientation": "horizontal", "stacking": "none", "tooltip": {"mode": "single", "sort": "desc"}, "xTickLabelRotation": 0},
      "title": "Findings by Detector",
      "type": "barchart",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sort_desc(sum by (detector) (monk_findings_total))", "legendFormat": "{{detector}}", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "high"}, "properties": [{"id": "color", "value": {"fixedColor": "#F2495C", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "medium"}, "properties": [{"id": "color", "value": {"fixedColor": "#FF9830", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "low"}, "properties": [{"id": "color", "value": {"fixedColor": "#73BF69", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 9, "w": 10, "x": 14, "y": 7},
      "id": 6,
      "options": {"displayLabels": ["name", "percent"], "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "pieType": "donut", "tooltip": {"mode": "single", "sort": "none"}},
      "title": "Severity Distribution",
      "type": "piechart",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(monk_findings_total{severity=\"high\"})", "legendFormat": "high", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(monk_findings_total{severity=\"medium\"})", "legendFormat": "medium", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(monk_findings_total{severity=\"low\"})", "legendFormat": "low", "refId": "C"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16},
      "id": 102,
      "title": "Cost & Waste",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "decimals": 2, "unit": "currencyUSD"},
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 14, "x": 0, "y": 17},
      "id": 7,
      "options": {"barRadius": 0.05, "barWidth": 0.7, "fillOpacity": 80, "groupWidth": 0.7, "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "orientation": "horizontal", "stacking": "none", "tooltip": {"mode": "single", "sort": "desc"}},
      "title": "Estimated Waste $/day by Detector",
      "type": "barchart",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sort_desc(monk_waste_usd_per_day > 0)", "legendFormat": "{{detector}}", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"fixedColor": "#F2495C", "mode": "fixed"}, "decimals": 2, "unit": "currencyUSD"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 10, "x": 14, "y": 17},
      "id": 8,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "title": "Projected Monthly Waste",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(monk_waste_usd_per_day) * 30", "legendFormat": "$/month", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 10, "x": 14, "y": 21},
      "id": 9,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "title": "LLM Calls Analyzed",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "monk_calls_analyzed_total", "legendFormat": "Calls", "refId": "A"}]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 26},
      "id": 103,
      "title": "Activity Over Time",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "High severity"}, "properties": [{"id": "color", "value": {"fixedColor": "#F2495C", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 27},
      "id": 10,
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "none"}},
      "title": "Findings Over Time",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(monk_findings_total)", "legendFormat": "All findings", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "monk_high_severity_findings_total", "legendFormat": "High severity", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "monk_calls_analyzed_total", "legendFormat": "Calls analyzed", "refId": "C"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["monk", "ai-agents", "llm", "observability", "cost"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "monk — AI Agent Cost Monitor",
  "uid": "monk-agent-costs",
  "version": 1
}
